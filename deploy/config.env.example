# デプロイ用の設定サンプル。
# このファイルをコピーして config.env を作り、自分の値を入れてください:
#   cp config.env.example config.env
# config.env は .gitignore 済みなので GitHub には push されません。

DOMAIN="example.com"          # 発行対象ドメイン (例: rps.example.com)
EMAIL="you@example.com"       # Let's Encrypt 通知用メール
EXTRA_DOMAINS=""              # 追加ドメイン(スペース区切り, 任意)。例: "www.example.com"
APP_PORT="8000"               # web_server.py が待ち受ける内部ポート
